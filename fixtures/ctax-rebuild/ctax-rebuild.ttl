# Layer 3 — the ctax-rebuild reasoning map.
# This is not a rule and not a fact. It is the SEMANTIC INTERSECTION that governs what
# SHAPE of response is permissible when a bailiff-present signal meets the ctax-rebuild
# domain. The Constitution (Layer 1) decides eligibility; this map decides the answer shape
# and the hard safety constraints the LLM must honour.
#
# The sov: vocabulary is the engine ontology — reused verbatim by EVERY domain. The domain is
# the literal value of sov:inDomain, never the namespace. sov: is a URN: an opaque identifier
# that is never dereferenced (no host, no DNS — nothing "local" at runtime).

@prefix sov:   <urn:sovereign:> .
@prefix shape: <urn:sovereign-shape:> .

sov:BailiffAtDoor a sov:SemanticIntersection ;
    sov:inDomain "ctax-rebuild" ;
    sov:whenSignal "bailiff_present" ;
    sov:requiresAnswerShape shape:UrgentSafeguardingGuidance ;
    sov:hasSafetyConstraint "no_payment_instruction" ,
                            "no_legal_advice_as_fact" ,
                            "must_signpost_emergency_support" ;
    sov:mustInclude "right_to_request_breathing_space" ,
                    "entry_rights_summary" ;
    sov:suppressResultPattern "ctr" ,
                              "council tax reduction" ,
                              "pensioner income" ,
                              "pensioner capital" ,
                              "income capital" ,
                              "working age ctr" ,
                              "local ctr policy" ,
                              "discount" ,
                              "premium" ;
    sov:allowSuppressedWhenQuestionPattern "can i get council tax reduction" ,
                                           "can i afford this" ,
                                           "income" ,
                                           "capital" ,
                                           "benefit" ,
                                           "ctr" ,
                                           "reduction" ,
                                           "discount" ;
    sov:overrides shape:StandardRebuildAnswerShape .
